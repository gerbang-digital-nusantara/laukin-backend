# Port container internal (jangan diubah, sudah selaras dengan compose & Dockerfile)
PORT=4000
# Port yang diekspos ke host VPS (dipakai nginx sebagai upstream)
APP_PORT=3085

# Connection string PostgreSQL (Neon) - wajib sslmode=require
DATABASE_URL=postgresql://user:password@host.region.aws.neon.tech/kang_lauk?sslmode=require

# Secret untuk tanda tangan JWT - ganti dengan string acak panjang
JWT_SECRET=ganti-dengan-secret-acak

# Daftar origin frontend yang diizinkan CORS, pisahkan dengan koma
CORS_ORIGINS=https://laukin-portal.web.app,https://laukin-publik.web.app
